{
  "description": "Loads brain index at session start and keeps it in sync when brain files change",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject-brain.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/auto-index-brain.sh"
          }
        ],
        "matcher": "brain/"
      }
    ]
  }
}
